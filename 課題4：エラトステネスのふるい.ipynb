    "i = 1\n",
    "for i in range(1 , 101):\n",
    "    if i == 1:\n",
    "        continue\n",
    "\n",
    "    elif i == 2 or i == 3 or i == 5 or i == 7:\n",
    "        print(i)\n",
    "\n",
    "    elif i % 2 == 0 or i % 3 == 0 or i % 5 == 0 or i % 7 == 0:\n",
    "        continue\n",
    "\n",
    "    else:\n",
    "        print(i)\n"
   ]
